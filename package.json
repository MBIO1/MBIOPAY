{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "preinstall": "npx echo 'Checking package manager...'",
    "build": "pnpm install --no-frozen-lockfile && pnpm run typecheck && pnpm -r --if-present run build",
    "build:api": "pnpm --dir artifacts/api-server build",
    "build:app": "pnpm --dir artifacts/app-ui build",
    "start": "pnpm --dir artifacts/api-server start",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "pnpm": {
    "overrides": {
      "picomatch@2": "2.3.2",
      "picomatch@4": "4.0.4"
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "prettier": "^3.2.5"
  }
}
