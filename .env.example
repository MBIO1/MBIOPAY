# .env.example

# SERVER CONFIG
SERVER_HOST=your_server_host
SERVER_PORT=your_server_port

# DATABASE
DB_HOST=your_database_host
DB_PORT=your_database_port
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password

# AUTHENTICATION
JWT_SECRET=your_jwt_secret
JWT_EXPIRATION=1h

# GOOGLE OAUTH
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# EMAIL SERVICE
EMAIL_SERVICE_TYPE=your_email_service_type
EMAIL_SERVICE_USER=your_email_service_user
EMAIL_SERVICE_PASS=your_email_service_pass

# TRON BLOCKCHAIN
TRON_NODE_URL=your_tron_node_url
TRON_PRIVATE_KEY=your_tron_private_key

# CORS & SECURITY
CORS_ORIGIN=your_frontend_url
CORS_CREDENTIALS=true
SECURE_COOKIES=true

# FRONTEND URLS
FRONTEND_URL=http://your_frontend_url

# PAYMENT PROCESSING
PAYMENT_GATEWAY_URL=http://your_payment_gateway_url
PAYMENT_API_KEY=your_payment_api_key

# LOGGING & MONITORING
LOG_LEVEL=info
LOG_FILE_PATH=/var/log/app.log

# THIRD-PARTY SERVICES
SERVICE_NAME_API_KEY=your_service_name_api_key
