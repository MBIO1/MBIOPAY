# .env.example

# SERVER CONFIG
PORT=3000
NODE_ENV=production

# PRIMARY APP DATABASE
# Required for auth, users, orders, admin, wallet stats, OTPs, and dashboard data.
# This app currently uses PostgreSQL for core product data.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# OPTIONAL MONGODB FEATURES
# Used for visit tracking, leads, referrals, and lightweight analytics only.
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER/mbio

# AUTHENTICATION & SESSIONS
JWT_SECRET=replace_me
REFRESH_SECRET=replace_me
ADMIN_SECRET=replace_me
SESSION_SECRET=replace_me

# GOOGLE OAUTH
GOOGLE_CLIENT_ID=replace_me
GOOGLE_CLIENT_SECRET=replace_me

# EMAIL / OTP
EMAIL_SERVICE_TYPE=smtp
EMAIL_SERVICE_USER=replace_me
EMAIL_SERVICE_PASS=replace_me

# WALLET / PAYOUTS
HOT_WALLET=replace_me
WALLET_ADDRESS=replace_me
HOT_PRIVATE_KEY=replace_me
TRON_API=replace_me
USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t

# PAYMENT PROVIDER
FLW_SECRET_KEY=replace_me

# CORS
CORS_ALLOWED_ORIGINS=https://mbiopay.com,https://www.mbiopay.com

# FRONTEND URLS
FRONTEND_URL=https://mbiopay.com

# LOGGING
LOG_LEVEL=info
